<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Category for AssetFlow -->
        <record id="module_category_assetflow" model="ir.module.category">
            <field name="name">AssetFlow</field>
            <field name="description">Helps you manage your enterprise assets and resources.</field>
            <field name="sequence">10</field>
        </record>

        <!-- Employee Group (Basic Access) -->
        <record id="group_assetflow_employee" model="res.groups">
            <field name="name">Employee</field>
            <field name="category_id" ref="module_category_assetflow"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">The user will be able to view their assets, book resources, and raise maintenance requests.</field>
        </record>

        <!-- Department Head Group -->
        <record id="group_assetflow_department_head" model="res.groups">
            <field name="name">Department Head</field>
            <field name="category_id" ref="module_category_assetflow"/>
            <field name="implied_ids" eval="[(4, ref('group_assetflow_employee'))]"/>
            <field name="comment">The user will be able to view departmental assets and approve departmental requests.</field>
        </record>

        <!-- Asset Manager Group -->
        <record id="group_assetflow_asset_manager" model="res.groups">
            <field name="name">Asset Manager</field>
            <field name="category_id" ref="module_category_assetflow"/>
            <field name="implied_ids" eval="[(4, ref('group_assetflow_department_head'))]"/>
            <field name="comment">The user will have full access to manage assets, approve maintenance, and run audits.</field>
        </record>

        <!-- Administrator Group -->
        <record id="group_assetflow_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="module_category_assetflow"/>
            <field name="implied_ids" eval="[(4, ref('group_assetflow_asset_manager'))]"/>
            <field name="comment">The user will have full configuration and master data management access.</field>
        </record>
        
        <!-- Base Admin gets AssetFlow Admin -->
        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('group_assetflow_admin'))]"/>
        </record>

    </data>
</odoo>
