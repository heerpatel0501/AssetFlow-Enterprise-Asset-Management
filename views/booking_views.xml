<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Booking Form View -->
    <record id="view_asset_flow_booking_form" model="ir.ui.view">
        <field name="name">asset_flow.booking.form</field>
        <field name="model">asset_flow.booking</field>
        <field name="arch" type="xml">
            <form string="Resource Booking">
                <header>
                    <button name="action_complete" string="Mark Completed" type="object" class="oe_highlight" invisible="state not in ['upcoming', 'ongoing']"/>
                    <button name="action_cancel" string="Cancel Booking" type="object" invisible="state in ['completed', 'cancelled']"/>
                    <field name="state" widget="statusbar" statusbar_visible="upcoming,ongoing,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="asset_id"/>
                            <field name="employee_id"/>
                        </group>
                        <group>
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Purpose of booking..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Booking Calendar View -->
    <record id="view_asset_flow_booking_calendar" model="ir.ui.view">
        <field name="name">asset_flow.booking.calendar</field>
        <field name="model">asset_flow.booking</field>
        <field name="arch" type="xml">
            <calendar string="Bookings" date_start="start_datetime" date_stop="end_datetime" color="asset_id" event_open_popup="true">
                <field name="employee_id" avatar_field="avatar_128"/>
                <field name="asset_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <!-- Booking Action -->
    <record id="action_asset_flow_booking" model="ir.actions.act_window">
        <field name="name">Resource Bookings</field>
        <field name="res_model">asset_flow.booking</field>
        <field name="view_mode">calendar,tree,form</field>
    </record>

    <!-- Menu for Bookings -->
    <record id="menu_asset_flow_bookings" model="ir.ui.menu">
        <field name="action" ref="action_asset_flow_booking"/>
    </record>
</odoo>
